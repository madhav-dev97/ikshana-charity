{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/trust-giving/dist/public",
        "buildCommand": "pnpm run vercel-build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!api/|_next/|.*\\.\\w+$).*)",
      "destination": "/index.html"
    }
  ]
}
